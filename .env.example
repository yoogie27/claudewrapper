# Server
DATA_DIR=./data
WEB_HOST=0.0.0.0
WEB_PORT=8645
TEST_MODE=false

# Claude Code CLI
CLAUDE_COMMAND_TEMPLATE=claude -p --prompt-file {prompt_path} --dangerously-skip-permissions --output-format stream-json
CLAUDE_PROMPT_VIA=prompt_file
CLAUDE_WORKDIR_MODE=project_path
USE_GIT_WORKTREES=true

# Limits
SESSION_TTL_DAYS=30
STALE_JOB_TIMEOUT_MINUTES=240

# GitHub (for auto-PR creation — see Settings page for setup guide)
GITHUB_TOKEN=

# SSH (optional — auto-generates keys at DATA_DIR/ssh if not set)
# SSH_KEY_DIR=/data/ssh
