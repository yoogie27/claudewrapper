# Core
LINEAR_API_KEY=
POLL_INTERVAL_SECONDS=60
WORKER_COUNT=3
SESSION_TTL_DAYS=30
DATA_DIR=./data
WEB_HOST=0.0.0.0
WEB_PORT=8645
TEST_MODE=false
REPO_ROOTS=
REPO_MAX_DEPTH=4
REPO_IGNORE_DIRS=.git;node_modules;dist;build;.venv;.idea;.vscode
HITL_STATE_NAME=
REVIEW_STATE_NAME=
DONE_STATE_NAME=
ERROR_STATE_NAME=

# Claude Code CLI integration
CLAUDE_COMMAND_TEMPLATE=claude -p "{prompt_text}" --resume "{session_id}" --dangerously-skip-permissions --output-format json
CLAUDE_PROMPT_VIA=prompt_file  # prompt_file or stdin or arg
CLAUDE_PROMPT_ARG=-p   	       # used when CLAUDE_PROMPT_VIA=arg
CLAUDE_WORKDIR_MODE=team_path  # team_path or repo_root or none
USE_GIT_WORKTREES=true
WORKTREE_ROOT=./data/worktrees

# Linear MCP server (optional)
LINEAR_MCP_ENABLED=false
LINEAR_MCP_COMMAND=
LINEAR_MCP_WORKDIR=

# Filtering
IGNORE_COMMENT_AUTHOR_IDS=
IGNORE_COMMENT_AUTHOR_EMAILS=

# Safety
MAX_ISSUES_PER_POLL=100

# Stale job recovery — requeues jobs stuck in 'running' after a server crash
# Set high enough to exceed your longest expected Claude session
STALE_JOB_TIMEOUT_MINUTES=240

# Linear webhooks (optional — reduces reliance on polling)
# Set this to the secret you configure in Linear's webhook settings
LINEAR_WEBHOOK_SECRET=

# GitHub auto-PR (optional — creates a PR after a successful session with commits)
GITHUB_TOKEN=

# Docker / SSH (for containerized deployment)
ANTHROPIC_API_KEY=
SSH_KEY_DIR=                    # e.g. /data/ssh — auto-generates ed25519 keypair for GitHub
REPOS_DIR=                      # e.g. /data/repos — auto-clone target for GitHub repo URLs
